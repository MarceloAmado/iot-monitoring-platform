{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "name": "IdeaMakers IoT Design Tokens",
  "version": "1.0.0",
  "color": {
    "brand": {
      "deep-blue": "#0F3C57",
      "deep-blue-hover": "#0a2d42",
      "deep-blue-light": "#1a5170",
      "orange": "#F57C20",
      "orange-hover": "#e66e12",
      "orange-soft": "#F9A45C",
      "orange-soft-hover": "#f89740"
    },
    "background": {
      "light": "#F5F5F5",
      "white": "#FFFFFF",
      "overlay": "rgba(0, 0, 0, 0.5)"
    },
    "neutral": {
      "900": "#0B1B26",
      "700": "#556E7A",
      "500": "#9AA9B3",
      "300": "#D6E0E6",
      "100": "#F0F4F7"
    },
    "status": {
      "success": "#2FB46E",
      "success-light": "#e8f6ef",
      "warning": "#F2C037",
      "warning-light": "#fef8e7",
      "danger": "#E04B4B",
      "danger-light": "#fde8e8",
      "info": "#4A90E2",
      "info-light": "#e8f2fc"
    },
    "device": {
      "online": "#2FB46E",
      "offline": "#9AA9B3",
      "maintenance": "#F2C037",
      "error": "#E04B4B"
    }
  },
  "font": {
    "family": {
      "heading": "\"Montserrat\", sans-serif",
      "body": "\"Open Sans\", ui-sans-serif, system-ui"
    },
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem"
    },
    "weight": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "lineHeight": {
      "tight": 1.25,
      "normal": 1.5,
      "relaxed": 1.75
    }
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem",
    "2xl": "3rem",
    "3xl": "4rem"
  },
  "borderRadius": {
    "none": "0",
    "sm": "0.375rem",
    "md": "0.75rem",
    "lg": "1rem",
    "full": "9999px"
  },
  "shadow": {
    "card": "0 6px 18px rgba(15, 60, 87, 0.08)",
    "card-hover": "0 8px 24px rgba(15, 60, 87, 0.12)",
    "modal": "0 20px 60px rgba(15, 60, 87, 0.25)",
    "focus": "0 0 0 3px rgba(245, 124, 32, 0.15)"
  },
  "transition": {
    "fast": "150ms cubic-bezier(0.4, 0, 0.2, 1)",
    "base": "200ms cubic-bezier(0.4, 0, 0.2, 1)",
    "slow": "300ms cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "breakpoint": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "layout": {
    "sidebar": {
      "expanded": "280px",
      "collapsed": "72px"
    },
    "topbar": {
      "height": "64px"
    },
    "container": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px",
      "2xl": "1440px"
    }
  },
  "zIndex": {
    "base": 0,
    "dropdown": 10,
    "sticky": 20,
    "modal": 50,
    "toast": 100
  }
}
