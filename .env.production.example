# ========================================
# Configuración de Producción
# Sistema IoT Monitoring
# ========================================

# IMPORTANTE: Copia este archivo a .env y modifica los valores
# NO commitear el archivo .env con valores reales

# === Base de Datos ===
DB_NAME=iot_monitoring
DB_USER=iot_admin
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO_AQUI  # Mínimo 12 caracteres
DB_HOST=postgres
DB_PORT=5432

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379

# === Backend ===
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=CAMBIAR_SECRET_KEY_JWT_MINIMO_32_CARACTERES_AQUI  # Generar con: openssl rand -hex 32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 horas

# === CORS (Agregar tu dominio o IP pública) ===
CORS_ORIGINS=https://iot.tuempresa.com,http://tu.ip.publica.aqui:3000

# === Frontend ===
VITE_API_BASE_URL=https://iot.tuempresa.com/api/v1  # Cambiar por tu dominio o IP
VITE_APP_NAME="IoT Monitoring System"
VITE_ENVIRONMENT=production

# === Logging ===
LOG_LEVEL=info  # debug | info | warning | error

# === MQTT ===
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=iot_backend
MQTT_PASSWORD=CHANGE_ME_MQTT_PASSWORD  # Cambiar si modificaste passwords.txt
MQTT_TOPIC_PREFIX=iot

# ========================================
# Configuración Opcional (Notificaciones)
# ========================================

# === Email (SMTP) ===
# Descomenta y configura si quieres notificaciones por email

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_email@gmail.com
# SMTP_PASSWORD=tu_app_password_aqui  # Gmail: App Password, no contraseña normal
# SMTP_FROM_EMAIL=noreply@iot-monitoring.com
# SMTP_FROM_NAME="IoT Monitoring System"

# === Telegram ===
# Descomenta y configura si quieres notificaciones por Telegram

# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=-1001234567890

# ========================================
# Notas de Configuración
# ========================================

# 1. DB_PASSWORD:
#    - Generar password seguro: openssl rand -base64 24
#    - Mínimo 12 caracteres, mezcla de letras, números y símbolos

# 2. SECRET_KEY (JWT):
#    - Generar: openssl rand -hex 32
#    - NUNCA reutilizar entre ambientes (dev/prod)
#    - Cambiar este valor invalida todos los tokens JWT

# 3. CORS_ORIGINS:
#    - Agregar TODAS las URLs desde donde se accederá al sistema
#    - Formato: https://dominio1.com,https://dominio2.com
#    - NO usar * en producción (inseguro)

# 4. VITE_API_BASE_URL:
#    - Debe ser la URL pública del backend
#    - Si usas Nginx, apuntar al dominio: https://iot.tuempresa.com/api/v1
#    - Si no usas dominio, usar IP: http://xxx.xxx.xxx.xxx:8000/api/v1

# 5. SMTP (Gmail):
#    - No usar contraseña normal, crear "App Password"
#    - Ir a: https://myaccount.google.com/apppasswords
#    - Generar password para "Mail" en "Other"

# 6. Telegram Bot:
#    - Crear bot con @BotFather en Telegram
#    - Obtener Chat ID: https://api.telegram.org/bot<TOKEN>/getUpdates
#    - Enviar mensaje al bot primero para obtener chat_id
