# ============================================================
# Sistema de Monitoreo IoT
# Archivo de Configuración de Variables de Entorno
# ============================================================
# IMPORTANTE: Copiar este archivo como .env y ajustar los valores
# Comando: cp .env.example .env

# ============================================================
# Base de Datos PostgreSQL
# ============================================================
DB_NAME=iot_monitoring
DB_USER=iot_admin
DB_PASSWORD=change_me_in_production_123!
DB_HOST=postgres
DB_PORT=5432

# URL completa de conexión (se construye automáticamente)
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ============================================================
# Redis (Cache y Sesiones)
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ============================================================
# Autenticación JWT
# ============================================================
# IMPORTANTE: Generar una clave secreta fuerte en producción
# Comando para generar: openssl rand -hex 32
JWT_SECRET_KEY=super_secret_jwt_key_change_this_in_production_xyz789
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================
# Configuración de FastAPI
# ============================================================
API_V1_PREFIX=/api/v1
PROJECT_NAME=IoT Monitoring System
VERSION=1.0.0

# ============================================================
# Entorno de Ejecución
# ============================================================
# Valores: development | production
ENVIRONMENT=development

# ============================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================
# En desarrollo: permitir localhost del frontend
# En producción: solo dominios específicos
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# Notificaciones por Email (SMTP)
# ============================================================
# Configuración para:
# - Alertas del sistema por email
# - Emails de recuperación de contraseña
# - Emails de bienvenida a nuevos usuarios
#
# SMTP_ENABLED: true para habilitar envío de emails (false = solo logs)
SMTP_ENABLED=false

# Gmail (recomendado para testing):
# 1. Activar 2FA en tu cuenta Google
# 2. Generar App Password: https://myaccount.google.com/apppasswords
# 3. Usar el App Password en SMTP_PASSWORD
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# SendGrid (recomendado para producción):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxx

# Mailgun (alternativa):
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@your-domain.mailgun.org
# SMTP_PASSWORD=your_mailgun_password

# Email del remitente (aparece en el "From")
SMTP_FROM_EMAIL=noreply@iot-monitoring.com
SMTP_FROM_NAME=Sistema de Monitoreo IoT

# Usar TLS/STARTTLS (dejar en true)
SMTP_TLS=true

# ============================================================
# Notificaciones por Telegram (Opcional)
# ============================================================
# Configuración para alertas por Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=-1001234567890

# ============================================================
# Frontend (Variables para Vite)
# ============================================================
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=IoT Monitoring System
VITE_ENVIRONMENT=development

# ============================================================
# Configuración de Logs
# ============================================================
LOG_LEVEL=INFO
# Valores: DEBUG | INFO | WARNING | ERROR | CRITICAL

# ============================================================
# Seguridad de Devices ESP32
# ============================================================
# API Key maestra para dispositivos (se debe cambiar en producción)
# Cada device debería tener su propia API key almacenada en la DB
DEVICE_API_KEY_SALT=random_salt_for_device_keys_xyz123

# ============================================================
# Encriptación (SCADA - Fase 0)
# ============================================================
# Clave Fernet para encriptar API Keys en la base de datos
# IMPORTANTE: Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Esta clave debe ser de 44 caracteres (32 bytes en base64url)
ENCRYPTION_KEY=CHANGE_ME_44_CHARACTERS_BASE64_ENCODED_KEY

# ============================================================
# MQTT Broker (SCADA - Fase 0)
# ============================================================
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_BROKER_WS_PORT=9001
# FASE 1.4: Autenticación habilitada
# La password real vive solo en tu .env local; regenerá el passwords.txt
# de Mosquitto con backend/scripts/mqtt_user_manager si la cambiás.
MQTT_USERNAME=iot_backend
MQTT_PASSWORD=CHANGE_ME_MQTT_PASSWORD
MQTT_CLIENT_ID=iot_backend_main
